{
  "name": "syntax-stories-webapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/install-shared-deps.cjs",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint . --max-warnings 50",
    "lint:src": "eslint src --max-warnings 50",
    "lint:strict": "eslint src --max-warnings 0",
    "lint:report": "node -e \"require('fs').mkdirSync('reports',{recursive:true})\" && eslint src -f json -o reports/eslint-report.json",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.18.3",
    "@syntax-stories/shared": "file:./packages/shared",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/core": "^2.3.0",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-underline": "^2.3.0",
    "@tiptap/react": "^2.3.0",
    "@tiptap/starter-kit": "^2.3.0",
    "altcha": "^2.3.0",
    "appwrite": "^23.0.0",
    "clsx": "^2.1.1",
    "country-state-city": "^3.2.1",
    "framer-motion": "^12.34.3",
    "highlight.js": "^11.11.1",
    "loaders.css": "^0.1.2",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.4",
    "mermaid": "^11.14.0",
    "motion": "^12.34.3",
    "next": "^16.2.2",
    "react": "^19.0.0",
    "react-activity-calendar": "^3.1.1",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "react-easy-crop": "^5.5.6",
    "react-loaders": "^3.0.1",
    "react-vertical-timeline-component": "^4.0.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
