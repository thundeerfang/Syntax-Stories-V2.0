# Backend API (existing Syntax Stories server)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Appwrite — Web platform (Console → Project → Add platform → Next.js)
# https://appwrite.io/docs/quick-starts/nextjs
# Browser SDK requires NEXT_PUBLIC_* (maps to Console “Project ID” / endpoint).
# In Appwrite Console → Web platform, add hostname: http://localhost:3000 (dev)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=syntaxstoriesv2
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=Syntax Stories
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
