# Copy to server/.env and adjust for Docker Compose.
# MongoDB stays external (Atlas or your host) — set MONGO_CONN.
#
# docker compose -f server/docker-compose.yml --env-file server/.env up -d --build

PORT=7373
NODE_ENV=production

# Required — your MongoDB connection string
MONGO_CONN=mongodb+srv://USER:PASS@cluster.mongodb.net/SyntaxStoriesV2

# Bundled Redis service (override if you use external Redis)
REDIS_URL=redis://redis:6379

# Bundled ClamAV service (leave host empty to disable virus scan)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_AUTO_START=false
CLAMAV_REQUIRED=false

# JWT / session (generate strong secrets for production)
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
SESSION_SECRET=change-me

# Comma-separated webapp + admin origins
FRONTEND_URL=https://yourdomain.com,https://admin.yourdomain.com
BACKEND_URL=https://api.yourdomain.com
PUBLIC_APP_URL=https://yourdomain.com

# Firebase FCM (mount server/secrets/firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT_PATH=/app/server/secrets/firebase-service-account.json

# Optional notification webhook worker (profile: webhook)
NOTIFICATION_WEBHOOK_PORT=7380
