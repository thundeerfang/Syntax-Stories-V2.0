# Syntax Stories API — copy to `.env` and fill in values.
# See README.md for full setup.

PORT=7373
MONGO_CONN=mongodb://127.0.0.1:27017/syntax-stories
FRONTEND_URL=http://localhost:3000

# Blog editor media search (server-side proxies — never expose these to mobile/web clients)
# GET /api/media/giphy/search
GIPHY_API_KEY=
# GET /api/media/unsplash/search (access key only; secret is not used by search)
UNSPLASH_ACCESS_KEY=
