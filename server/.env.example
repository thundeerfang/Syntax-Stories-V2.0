# Server
PORT=7373
NODE_ENV=development
# In production, set frontend URL(s). Comma-separated for multiple. Use *.vercel.app to allow all Vercel preview origins.
# Include the admin app origin for CORS (e.g. http://localhost:3002) or set ADMIN_FRONTEND_URL if your server supports it.
FRONTEND_URL=http://localhost:3001,http://localhost:3002
BACKEND_URL=http://localhost:7373

# Database
MONGO_CONN=mongodb://localhost:27017/syntax-stories

# Local Redis (start: brew services start redis). Connection URL = your local “credentials”.
REDIS_URL=redis://127.0.0.1:6379

# JWT Auth — set to 7d so users stay logged in 7 days. Session is extended on each /auth/refresh.
# If you use 15m or 1h, access tokens expire often; the client will refresh automatically if it has a refresh token.
JWT_SECRET=your-jwt-access-secret
# Optional: separate HMAC key for email OTP hashes in Redis (defaults to JWT_SECRET)
# OTP_PEPPER=
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

SESSION_SECRET=your-session-secret-min-32-chars

# Email Configuration (Gmail – use App Password: https://support.google.com/mail/?p=InvalidSecondFactor)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-google-app-password

# Optional: Resend API (HTTPS) — used if SMTP fails, or alone if you omit SMTP password
# RESEND_API_KEY=re_...
# RESEND_FROM=onboarding@resend.dev

# Email OTP
# OTP_LOGIN_TTL_SECONDS=300
# OTP_SIGNUP_TTL_SECONDS=600
# OTP_MIN_RESEND_SECONDS=60

# ALTCHA proof-of-work (widget + GET /auth/altcha/challenge). Uses JWT_SECRET if unset.
# ALTCHA_HMAC_KEY=long-random-secret
# ALTCHA_REQUIRED=true

# Cloudinary (optional – use if server uploads assets)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth
GOOGLE_CLOUD_COMPUTING=your-google-client-id
GOOGLE_CLOUD_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLOUD_SECRET=your-github-client-secret

# Security
IDEMPOTENCY_TTL_SEC=86400
INTENT_TTL_SEC=300

# ClamAV (optional — uploads scanned via clamd TCP INSTREAM; default local install has no TCP password on 127.0.0.1)
# First-time: bash server/scripts/setup-clamav-homebrew.sh
# Local “credentials” are host + port (not a password unless you configure clamd with one):
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
# In NODE_ENV=development, default true: server runs `brew services start clamav` and/or spawns clamd if 3310 is closed.
CLAMAV_AUTO_START=true
# CLAMD_PATH=/opt/homebrew/opt/clamav/sbin/clamd
# CLAMD_CONF=/opt/homebrew/etc/clamav/clamd.conf
# When true, image uploads fail with 503 if CLAMAV_HOST is unset or clamd is down:
# CLAMAV_REQUIRED=false

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# X (Twitter) OAuth (X_CONSUMER_* or X_CLIENT_ID / X_CLIENT_SECRET from developer portal)
X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret

# OpenCorporates (optional – for company name search in work experience; get free key at https://opencorporates.com/api_accounts/new)
OPENCORPORATES_API_TOKEN=

# Stripe subscriptions (INR monthly prices — create Products/Prices in Dashboard, paste price_ IDs)
# Webhook URL: POST https://<your-api-host>/webhooks/stripe  (raw body; register before JSON parser)
# Local: `stripe listen --forward-to localhost:7373/webhooks/stripe` and paste the signing secret below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PROPLUS=
STRIPE_PRICE_ULTRA=
# Public site URL for Checkout success/cancel (defaults to first FRONTEND_URL entry)
PUBLIC_APP_URL=http://localhost:3001
STRIPE_PORTAL_RETURN_URL=http://localhost:3001/settings?section=payments
# POST /api/internal/billing/replay-webhook — header X-Internal-Billing-Secret
INTERNAL_BILLING_SECRET=
# BILLING_SYNC_STALE_SEC=120
# BILLING_SUMMARY_CACHE_TTL_SEC=60
# BILLING_WEBHOOK_RETRY_MS=60000
# BILLING_RECONCILE_INTERVAL_MS=21600000
# BILLING_RECONCILE_SHARD_PCT=5
# BILLING_WEBHOOK_MAX_RETRIES=25

# Platform admin RBAC: `false` = staff JWT only (no per-permission checks) for /api/v1/admin/management/*
# FEATURE_ADMIN_RBAC_ENABLED=true

# Legal / consent (§21, §44, §56) — `/api/v1/legal/*`, `/api/health/legal`
LEGAL_ENFORCEMENT_MODE=soft
# strict = block writes (except allowlist) when user must re-accept latest Terms/Privacy
LEGAL_ENFORCEMENT_MODE=strict
LEGAL_DELETION_COOLDOWN_HOURS=24
LEGAL_DELETION_SLA_DAYS=30
LEGAL_JOB_POLL_MS=5000
LEGAL_INTEGRITY_INTERVAL_MS=86400000
