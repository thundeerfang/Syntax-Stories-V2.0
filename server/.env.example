# Server
PORT=7373
NODE_ENV=development
# In production, set frontend URL(s). Comma-separated for multiple. Use *.vercel.app to allow all Vercel preview origins.
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:7373

# Database
MONGO_CONN=mongodb://localhost:27017/syntax-stories
REDIS_URL=redis://127.0.0.1:6380

# JWT Auth — set to 7d so users stay logged in 7 days. Session is extended on each /auth/refresh.
# If you use 15m or 1h, access tokens expire often; the client will refresh automatically if it has a refresh token.
JWT_SECRET=your-jwt-access-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

SESSION_SECRET=your-session-secret-min-32-chars

# Email Configuration (Gmail – use App Password: https://support.google.com/mail/?p=InvalidSecondFactor)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-google-app-password

# Cloudinary (optional – use if server uploads assets)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth
GOOGLE_CLOUD_COMPUTING=your-google-client-id
GOOGLE_CLOUD_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLOUD_SECRET=your-github-client-secret

# Security
IDEMPOTENCY_TTL_SEC=86400
INTENT_TTL_SEC=300

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# X (Twitter) OAuth (X_CONSUMER_* or X_CLIENT_ID / X_CLIENT_SECRET from developer portal)
X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret

# OpenCorporates (optional – for company name search in work experience; get free key at https://opencorporates.com/api_accounts/new)
OPENCORPORATES_API_TOKEN=
