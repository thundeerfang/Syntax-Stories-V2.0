# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/syntax-stories
# or MONGO_CONN=mongodb://localhost:27017/syntax-stories

# Redis (rate limit, session store, idempotency, OTP). Omit for in-memory fallbacks.
REDIS_URL=redis://localhost:6379

# Session (express-session). Use a strong secret.
SESSION_SECRET=your-session-secret-min-32-chars

# JWT – Access token uses RSA RS256; place privateKey.pem and publicKey.pem in server/keys/
# Generate with: npm run generate-keys
JWT_SECRET=your-access-secret-or-fallback
JWT_REFRESH_SECRET=your-different-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Auth
BCRYPT_ROUNDS=12
FRONTEND_URL=https://syntax-stories.vercel.app
# Backend base URL (for OAuth callback URLs)
BACKEND_URL=https://your-api.example.com

# Idempotency
IDEMPOTENCY_TTL_SEC=86400

# Email (OTP via Gmail; use Google App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-google-app-password
EMAIL_PASS=fallback-if-EMAIL_APP_PASSWORD-not-set

# Google OAuth
GOOGLE_CLOUD_COMPUTING=your-google-client-id
GOOGLE_CLOUD_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLOUD_SECRET=your-github-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# X (Twitter) OAuth
X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret
