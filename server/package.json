{
  "name": "server",
  "version": "1.0.0",
  "description": "Express TypeScript MVC backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:clean": "rimraf dist && npm run dev",
    "generate-keys": "node scripts/generate-keys.js",
    "reconcile:follow-counts": "node --loader ts-node/esm src/scripts/reconcileFollowCounts.ts",
    "referral:integrity": "tsx src/scripts/referralIntegrityCheck.ts",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.16",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "altcha-lib": "^1.4.1",
    "connect-redis": "^8.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-oauth2": "^1.8.0",
    "passport-twitter": "^0.1.5",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "sharp": "^0.33.5",
    "speakeasy": "^2.0.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "overrides": {
    "passport-oauth": {
      "passport": "^0.7.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/passport-oauth2": "^1.8.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.26.1"
  }
}
