{
  "name": "syntax-stories-desktop",
  "version": "1.0.0",
  "private": true,
  "author": "Syntax Stories",
  "description": "Syntax Stories desktop shell (Electron) — OTP auth against the common API server",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "tsc --noEmit && vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^35.1.0",
    "electron-builder": "^26.0.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.syntaxstories.desktop",
    "productName": "Syntax Stories",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.cjs"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
